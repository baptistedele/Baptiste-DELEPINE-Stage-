
sudo nano /usr/local/bin/batman-start.sh 
#(permet la création et l'accessibilité du script) 

#!/bin/bash 

#(initialise le type de fichier du script soit bash)

sudo nmcli device disconnect wlan0 
                
nmcli device set wlan0 managed no
sudo ip link set wlan0 down

#(permet la déconnexion du wifi)

sudo iw dev wlan0 set type ibss
sudo ip link set wlan0 up
sudo iw dev wlan0 ibss join mon-mesh-pi 2437 02:AA:BB:CC:DD:EE

#(connexion au réseau ad hoc)

sudo modprobe batman-adv

#(activation du protocole BATMAN batman-adv)

sleep 2  

#(permet une attente de 2 secondes avant la reprise des commandes suivantes)

sudo batctl routing_algo BATMAN_IV 

#(Définition de l'algorythme de routage utilisé par batman-adv 

sudo batctl if add wlan0

#(permet d'ajouter une iterface wlan0 à BATMAN)

sudo ip link set up dev bat0

#(permet l'activation d'une interface bat0 du module batman-adv)

sudo ip addr add 192.168.99.4/24 dev bat0 

#(permet l'attribution d'une adresse IP sur l'interface bat0)

sudo ip addr add 192.168.50.3/24 dev eth0   

#(permet l'attribution d'une adresse IP sur l'interface eth0)

ip link set up dev eth0

#(Active l'interface eth0)
